# =============================================================================
# xchain-memebot — environment
# Copy to `.env` and fill in. NEVER commit `.env`.
# Everything marked (YOU: LATER) is a key you said you'll provide when ready.
# The bot boots without them, but any flow needing one will error clearly.
# =============================================================================

# --- Telegram -----------------------------------------------------------------
# (YOU: LATER) From @BotFather
TELEGRAM_BOT_TOKEN=

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
# Master switch. Stays false until preflight + your go-ahead. When false the bot
# will onboard/quote/show balances but REFUSE to broadcast any trade.
TRADING_ENABLED=false

# --- Robinhood Chain (MAINNET, chain id 4663 / 0x1237) ------------------------
# Public RPC works out of the box; Alchemy strongly recommended for reliability.
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com
# (YOU: LATER) Alchemy — used as primary RPC AND the ERC-4337 bundler later.
# https://robinhood-mainnet.g.alchemy.com/v2/<KEY>
ALCHEMY_RH_RPC_URL=
RH_WS_FEED_URL=wss://feed.mainnet.chain.robinhood.com
RH_EXPLORER_API=https://robinhoodchain.blockscout.com/api

# --- Solana -------------------------------------------------------------------
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# (YOU: LATER) A paid Solana RPC (Helius/Triton/Alchemy) — public RPC will rate-limit.
SOLANA_RPC_URL_PAID=

# --- Custody backend ----------------------------------------------------------
# 'local'  = per-user keys generated + AES-256-GCM encrypted at rest (needs
#            ENCRYPTION_KEY). Fully functional, no external dependency.
# 'turnkey'= Turnkey TEE custody (fill TURNKEY_* below).
# 'auto'   = turnkey when TURNKEY_ORGANIZATION_ID is set, else local.
CUSTODY_PROVIDER=auto

# --- Turnkey (custody / signing) — only if CUSTODY_PROVIDER=turnkey ------------
# https://app.turnkey.com  — org id + an API key pair for the backend.
TURNKEY_API_BASE_URL=https://api.turnkey.com
TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=

# --- Relay (cross-chain rail) -------------------------------------------------
RELAY_API_BASE=https://api.relay.link
# Fee treasuries. Relay pays app fees in the ORIGIN currency: buys (Solana origin)
# pay to the SOLANA address, sells (RH origin) to the EVM address. Set both.
FEE_TREASURY_EVM=
FEE_TREASURY_SOL=
# Fee taken on each trade, in basis points (100 = 1%).
APP_FEE_BPS=100

# --- Uniswap Trading API (swap calldata) --------------------------------------
# Confirmed reachable for chain 4663 but REQUIRES an api key (401 without one).
# (YOU: LATER) https://hub.uniswap.org / Trading API access.
UNISWAP_TRADING_API=https://trade-api.gateway.uniswap.org/v1
UNISWAP_API_KEY=

# --- Gas top-up (MVP sell path) -----------------------------------------------
# (YOU: LATER) Private key of an ISOLATED hot wallet that fronts dust ETH on RH
# Chain so gas-less users can sell. Keep it low-balance + monitored.
GAS_TANK_PRIVATE_KEY=
# Ceiling of ETH (wei) we'll ever push in a single top-up. Anti-drain guard.
GAS_TANK_MAX_TOPUP_WEI=2000000000000000

# --- Database -----------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/xchain_memebot

# --- Safety knobs -------------------------------------------------------------
# Default slippage for the destination/sell swap (bps). Memecoins are thin.
DEFAULT_SLIPPAGE_BPS=800
# Hard cap a single buy can spend (USD-ish, enforced in app logic).
MAX_BUY_USD=500
# Withdrawals are held this long before executing (seconds). Anti-account-takeover.
WITHDRAWAL_DELAY_SECONDS=7200

# --- Production / deployment ---------------------------------------------------
# polling = simple/local. webhook = public prod behind HTTPS.
BOT_MODE=polling
# HTTP port for health check (+ webhook endpoint in webhook mode).
PORT=8080
# Public HTTPS base Telegram will POST updates to (webhook mode only).
WEBHOOK_DOMAIN=
# Random secret guarding the webhook path/header. Generate: openssl rand -hex 24
WEBHOOK_SECRET=
# Redis for sessions/locks. REQUIRED in prod. Empty ⇒ in-memory (single instance).
REDIS_URL=
# Background workers (withdrawals, order recovery, deposit detection).
ENABLE_WORKERS=true
# true = workers in the bot process. false = run `npm run start:worker` separately.
RUN_WORKERS_IN_PROCESS=true
# Telegram user ids allowed to use admin controls (comma-separated).
ADMIN_TELEGRAM_IDS=
# 32-byte hex, encrypts 2FA secrets at rest. REQUIRED in prod. Generate: openssl rand -hex 32
ENCRYPTION_KEY=
